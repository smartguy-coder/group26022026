function doGet(reg) {
  var doc = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = doc.getSheetByName('Відповіді форми (1)');
  var values = sheet.getDataRange().getValues();

  var output = [];

  for(var i = 1; i < values.length; i++){
    var row = {};
    row['name'] = values[i][1];
    row['surname'] = values[i][2];
    row['charity'] = values[i][3];
    row['date'] = values[i][5];
    output.push(row);

  }
  return ContentService.createTextOutput(JSON.stringify({trip: output, count: output.length, full_table: false})).setMimeType(ContentService.MimeType.JSON);

}
